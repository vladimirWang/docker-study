DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=myapp_test
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_URL="mysql://root:123456@localhost:3306/myapp_test"

