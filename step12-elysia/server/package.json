    "migrate:dev": "bunx dotenv -e .env.dev -- prisma migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "7.4.2",
    "@prisma/client": "7.4.2",
    "@redis/client": "5.11.0",
    "dotenv": "17.3.1",
    "elysia": "latest",
    "pino": "9.5.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "dotenv-cli": "11.0.0",
    "prisma": "7.4.2"
  },
  "module": "src/index.js"
}
